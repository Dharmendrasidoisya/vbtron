<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

	RewriteCond %{HTTP_HOST} !^www\. [NC] 
	RewriteRule ^ https://spmengineers.com/REQUEST_URI} [R=301,L,NE]

	RewriteCond %{THE_REQUEST} ^[A-Z]+\ /([^/]+/)*index(\.[a-z0-9]+)?[^\ ]*\ HTTP/
	RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/[0-9a-zA-Z_-]+$
	RewriteCond %{REQUEST_URI} !^/\.well-known/cpanel-dcv/[0-9a-zA-Z_-]+$
	RewriteCond %{REQUEST_URI} !^/\.well-known/pki-validation/[A-F0-9]{32}\.txt(?:\ Comodo\ DCV)?$
	RewriteRule ^(([^/]+/)*)index(\.[a-z0-9]+)?$ https://spmengineers.com/$1? [R=301,L]
	
	Redirect 301 /services/legal-assistance https://www.spmengineers.com/services/financial-legal-assistance
	Redirect 301 /blogs/all-about-outsourcing-accounts-receivable-management-services https://www.spmengineers.com/blogs/outsourcing-accounts-receivable-management-services
	Redirect 301 /blogs/virtual-accounting-company https://www.spmengineers.com/blogs/virtual-accounting-company-in-ahmedabad
	Redirect 301 /blogs/securing-your-business-a-complete-guide-to-audit-and-assurance-services https://www.spmengineers.com/blogs/audit-and-assurance-services-in-ahmedabad
	Redirect 301 /blogs/quickbooks-bookkeeping-services-in-ahmedabad https://www.spmengineers.com/blogs/quickbooks-bookkeeping-services-in-india
	Redirect 301 /usa https://www.spmengineers.com/audit-tax-accounting-usa
</IfModule>
